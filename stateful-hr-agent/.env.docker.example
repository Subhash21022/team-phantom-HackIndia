# Docker env template for local containers
# Copy this to .env before running docker compose

# Azure OpenAI (required for full agent mode)
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_AGENT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini

# Optional integrations
SUPABASE_BUCKET=hr-documents
GOOGLE_CREDENTIALS_FILE=credentials.json

# Service defaults
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
